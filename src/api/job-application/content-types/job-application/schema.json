{
  "kind": "collectionType",
  "collectionName": "job_applications",
  "info": {
    "singularName": "job-application",
    "pluralName": "job-applications",
    "displayName": "Job Application"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phoneNumber": {
      "type": "string"
    },
    "linkedInURL": {
      "type": "string"
    },
    "portfolioURL": {
      "type": "string"
    },
    "Resume": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "coverLetter": {
      "type": "text"
    },
    "applicationStatus": {
      "type": "enumeration",
      "enum": [
        "New",
        "Under Review",
        "Shortlisted",
        "Interview Scheduled",
        "Rejected",
        "Hired"
      ]
    },
    "job_positions": {
      "type": "string"
    }
  }
}
